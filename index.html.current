<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

<meta name="mobile-web-app-capable" content="yes">

<meta name="apple-mobile-web-app-capable" content="yes">

<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

<title>KSG Tag Generator System</title>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script src="supabase-config.js"></script>

<script src="supabase-db.js"></script>

<script defer src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script defer src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<script defer src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>

<script defer src="https://cdn.jsdelivr.net/npm/xlsx@0.18.1/dist/xlsx.full.min.js"></script>

<script src="js/shared.js"></script>

<script src="js/dashboard.js"></script>

<script src="js/generate-tag.js"></script>

<script src="js/manage-tags.js"></script>

<script src="js/bulk-generation.js"></script>

<script src="js/reports.js"></script>

<script src="js/settings.js"></script>

<script src="js/activity-logs.js"></script>

<script src="js/text-styling.js"></script>

<style>

  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');


  :root {

    --ksg-dark: #0A1628;

    --ksg-navy: #0D2147;

    --ksg-blue: #1A3A6B;

    --ksg-gold: #C9A84C;

    --ksg-gold-light: #E8C870;

    --ksg-cream: #F7F3EC;

    --ksg-white: #FFFFFF;

    --ksg-gray: #8A95A3;

    --ksg-light: #EEF2F7;

    --ksg-success: #2ECC71;

    --ksg-danger: #E74C3C;

    --ksg-warning: #F39C12;

    --sidebar-w: 260px;

    --radius: 12px;

    --shadow: 0 4px 24px rgba(10,22,40,0.12);

    --shadow-lg: 0 12px 48px rgba(10,22,40,0.18);

  }


  * { margin:0; padding:0; box-sizing:border-box; }


  body {

    font-family: 'DM Sans', sans-serif;

    background: var(--ksg-light);

    color: var(--ksg-dark);

    min-height: 100vh;

  }


  /* ─── AUTH ─── */

  #auth-screen {

    min-height: 100vh;

    display: flex;

    align-items: center;

    justify-content: center;

    background: linear-gradient(135deg, var(--ksg-dark) 0%, var(--ksg-blue) 60%, #2A5298 100%;

    position: relative;

    overflow: hidden;

  }

  #auth-screen::before {

    content: '';

    position: absolute;

    width: 600px; height: 600px;

    border-radius: 50%;

    background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%);

    top: -200px; right: -150px;

  }

  #auth-screen::after {

    content: '';

    position: absolute;

    width: 400px; height: 400px;

    border-radius: 50%;

    background: radial-gradient(circle, rgba(26,58,107,0.4) 0%, transparent 70%);

    bottom: -100px; left: -80px;

  }

  .auth-card {

    background: rgba(255,255,255,0.06);

    -webkit-backdrop-filter: blur(24px);

    backdrop-filter: blur(24px);

    border: 1px solid rgba(201,168,76,0.25);

    border-radius: 20px;

    padding: 48px 44px;

    width: 440px;

    max-width: 94vw;

    position: relative;

    z-index: 1;

    box-shadow: 0 24px 80px rgba(0,0,0,0.4);

  }

  .auth-logo {

    text-align: center;

    margin-bottom: 32px;

  }

  .auth-logo .crest {

    width: 72px; height: 72px;

    background: linear-gradient(135deg, var(--ksg-gold), var(--ksg-gold-light));

    border-radius: 50%;

    display: inline-flex;

    align-items: center;

    justify-content: center;

    font-size: 32px;

    margin-bottom: 14px;

    box-shadow: 0 8px 24px rgba(201,168,76,0.35);

  }

  .auth-logo h1 {

    font-family: 'Playfair Display', serif;

    color: var(--ksg-white);

    font-size: 1.5rem;

    line-height: 1.2;

  }

  .auth-logo p { color: var(--ksg-gold); font-size: 0.78rem; letter-spacing: 2px; text-transform: uppercase; margin-top: 4px; }

  .auth-tabs { display: flex; gap: 0; margin-bottom: 28px; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.12); }

  .auth-tab {

    flex: 1; padding: 10px; text-align: center;

    cursor: pointer; color: rgba(255,255,255,0.5);

    font-size: 0.88rem; font-weight: 500;

    transition: all 0.2s;

    background: transparent;

    border: none;

  }

  .auth-tab.active { background: var(--ksg-gold); color: var(--ksg-dark); font-weight: 600; }

  .form-group { margin-bottom: 18px; }

  .form-group label { display: block; color: rgba(255,255,255,0.7); font-size: 0.82rem; margin-bottom: 7px; font-weight: 500; }

  .form-group input, .form-group select {

    width: 100%; padding: 12px 16px;

    background: rgba(255,255,255,0.08);

    border: 1px solid rgba(255,255,255,0.15);

    border-radius: 8px;

    color: var(--ksg-white);

    font-size: 0.9rem;

    font-family: 'DM Sans', sans-serif;

    transition: border-color 0.2s;

    outline: none;

  }

  .form-group input:focus, .form-group select:focus { border-color: var(--ksg-gold); }

  .form-group input::placeholder { color: rgba(255,255,255,0.3); }

  .form-group select option { background: var(--ksg-navy); }

  .btn-primary {

    width: 100%; padding: 13px;

    background: linear-gradient(135deg, var(--ksg-gold), var(--ksg-gold-light));

    border: none; border-radius: 8px;

    color: var(--ksg-dark); font-weight: 700;

    font-size: 0.95rem; cursor: pointer;

    font-family: 'DM Sans', sans-serif;

    transition: all 0.2s;

    letter-spacing: 0.5px;

  }

  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(201,168,76,0.4); }

  .auth-note { text-align: center; color: rgba(255,255,255,0.4); font-size: 0.78rem; margin-top: 20px; }

  .auth-note a { color: var(--ksg-gold); cursor: pointer; }

  .auth-form { display: none; }

  .auth-form.active { display: block; }

  .alert { padding: 10px 14px; border-radius: 8px; font-size: 0.84rem; margin-bottom: 16px; }

  .alert-error { background: rgba(231,76,60,0.15); border: 1px solid rgba(231,76,60,0.3); color: #FF8B7E; }

  .alert-success { background: rgba(46,204,113,0.15); border: 1px solid rgba(46,204,113,0.3); color: #7EE8A2; }


  /* ─── APP SHELL ─── */

  #app { display: none; }

  .app-layout { display: flex; min-height: 100vh; }


  /* ─── SIDEBAR ─── */

  .sidebar {

    width: var(--sidebar-w);

    background: var(--ksg-dark);

    display: flex; flex-direction: column;

    position: fixed; top: 0; left: 0;

    height: 100vh; z-index: 100;

    transition: transform 0.3s;

  }

  .sidebar-logo {

    padding: 24px 20px;

    border-bottom: 1px solid rgba(255,255,255,0.06);

  }

  .sidebar-logo .logo-mark {

    width: 40px; height: 40px;

    background: linear-gradient(135deg, var(--ksg-gold), var(--ksg-gold-light));

    border-radius: 10px;

    display: inline-flex; align-items: center; justify-content: center;

    font-size: 18px; margin-bottom: 10px;

  }

  .sidebar-logo h2 { color: var(--ksg-white); font-family: 'Playfair Display', serif; font-size: 1.05rem; }

  .sidebar-logo span { color: var(--ksg-gold); font-size: 0.72rem; letter-spacing: 1.5px; text-transform: uppercase; }

  .sidebar-nav { flex: 1; padding: 16px 12px; overflow-y: auto; }

  .nav-section { margin-bottom: 24px; }

  .nav-section-label { color: rgba(255,255,255,0.3); font-size: 0.68rem; letter-spacing: 2px; text-transform: uppercase; padding: 0 8px; margin-bottom: 6px; }

  .nav-item {

    display: flex; align-items: center; gap: 12px;

    padding: 10px 12px; border-radius: 8px;

    color: rgba(255,255,255,0.55); font-size: 0.87rem;

    cursor: pointer; transition: all 0.2s; margin-bottom: 2px;

    border: none; background: none; width: 100%; text-align: left;

    font-family: 'DM Sans', sans-serif;

  }

  .nav-item:hover { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.85); }

  .nav-item.active { background: rgba(201,168,76,0.12); color: var(--ksg-gold); }

  .nav-item .nav-icon { font-size: 1rem; width: 20px; text-align: center; }

  .nav-badge { margin-left: auto; background: var(--ksg-gold); color: var(--ksg-dark); font-size: 0.68rem; font-weight: 700; padding: 2px 7px; border-radius: 20px; }

  .sidebar-footer { padding: 16px 12px; border-top: 1px solid rgba(255,255,255,0.06); margin-top: auto; }

  .user-info { display: flex; align-items: center; gap: 10px; padding: 8px; }

  .user-avatar { width: 36px; height: 36px; background: linear-gradient(135deg, var(--ksg-gold), var(--ksg-gold-light)); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--ksg-dark); font-size: 0.85rem; flex-shrink: 0; }

  .user-details { flex: 1; min-width: 0; }

  .user-name { color: var(--ksg-white); font-size: 0.85rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .user-role { color: var(--ksg-gray); font-size: 0.72rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .btn-logout { background: none; border: none; cursor: pointer; color: rgba(255,255,255,0.8); font-size: 1.1rem; padding: 4px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

  .btn-logout:hover { color: var(--ksg-danger); }


  /* ─── MAIN CONTENT ─── */

  .main-content {

    margin-left: var(--sidebar-w);

    flex: 1; min-height: 100vh;

    display: flex; flex-direction: column;

  }

  .topbar {

    background: var(--ksg-white);

    padding: 0 32px;

    height: 64px;

    display: flex; align-items: center;

    border-bottom: 1px solid rgba(0,0,0,0.06);

    position: sticky; top: 0; z-index: 50;

    gap: 16px;

    box-shadow: 0 2px 8px rgba(0,0,0,0.04);

  }

  .topbar-title { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: var(--ksg-dark); flex: 1; }

  .topbar-search {

    display: flex; align-items: center;

    background: var(--ksg-light); border-radius: 8px;

    padding: 8px 14px; gap: 8px; width: 260px;

  }

  .topbar-search input { background: none; border: none; outline: none; font-size: 0.87rem; color: var(--ksg-dark); width: 100%; font-family: 'DM Sans', sans-serif; }

  .topbar-actions { display: flex; align-items: center; gap: 10px; }

  .topbar-btn {

    width: 36px; height: 36px; border-radius: 8px;

    background: var(--ksg-light); border: none;

    cursor: pointer; display: flex; align-items: center; justify-content: center;

    color: var(--ksg-gray); font-size: 1rem; transition: all 0.2s; position: relative;

  }

  .topbar-btn:hover { background: var(--ksg-dark); color: white; }

  .notif-dot { position: absolute; top: 6px; right: 6px; width: 7px; height: 7px; background: var(--ksg-danger); border-radius: 50%; }

  .hamburger { display: none; }

  .page-content { padding: 28px 32px; flex: 1; }


  /* ─── PAGES ─── */

  .page { display: none; }

  .page.active { display: block; }


  /* ─── DASHBOARD ─── */

  .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; margin-bottom: 28px; }

  .stat-card {

    background: var(--ksg-white);

    border-radius: var(--radius);

    padding: 22px 24px;

    box-shadow: var(--shadow);

    position: relative; overflow: hidden;

  }

  .stat-card::before {

    content: '';

    position: absolute; top: 0; left: 0; right: 0; height: 3px;

  }

  .stat-card.gold::before { background: linear-gradient(90deg, var(--ksg-gold), var(--ksg-gold-light)); }

  .stat-card.blue::before { background: linear-gradient(90deg, #1A3A6B, #2A5298); }

  .stat-card.green::before { background: linear-gradient(90deg, #2ECC71, #27AE60); }

  .stat-card.red::before { background: linear-gradient(90deg, #E74C3C, #C0392B); }

  .stat-icon { font-size: 1.8rem; margin-bottom: 12px; }

  .stat-value { font-size: 2rem; font-weight: 700; color: var(--ksg-dark); line-height: 1; margin-bottom: 4px; }

  .stat-label { color: var(--ksg-gray); font-size: 0.82rem; }

  .stat-change { font-size: 0.78rem; margin-top: 8px; color: var(--ksg-success); }


  .dash-grid { display: grid; grid-template-columns: 1fr 340px; gap: 20px; }

  .card {

    background: var(--ksg-white);

    border-radius: var(--radius);

    box-shadow: var(--shadow);

    overflow: hidden;

  }

  .card-header {

    padding: 18px 24px;

    border-bottom: 1px solid var(--ksg-light);

    display: flex; align-items: center; justify-content: space-between;

  }

  .card-title { font-family: 'Playfair Display', serif; font-size: 1rem; color: var(--ksg-dark); }

  .card-body { padding: 20px 24px; }

  .card-body--flush { padding: 0; }

  .card-title--small { font-size: 0.88rem; margin-bottom: 12px; }

  .text-muted-light { color: rgba(255,255,255,0.5); font-size: 0.8rem; }

  .field-hidden { display: none; }

  .style-panel { margin-top: 18px; padding-top: 14px; border-top: 1px solid var(--ksg-light); }

  .style-panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }

  .style-panel-title { margin: 0; }

  .style-panel-select { padding: 6px 8px; font-size: 0.78rem; }

  .style-panel-select--compact { width: auto; }

  .style-panel-select--full { width: 100%; }

  .style-panel-controls { display: grid; grid-template-columns: 1fr; gap: 8px; font-size: 0.72rem; }

  .style-panel-row { display: flex; justify-content: space-between; }

  .style-panel-range { width: 100%; }

  .style-panel-inline { display: flex; align-items: center; gap: 14px; padding-top: 4px; }

  .style-panel-check { display: flex; align-items: center; gap: 6px; margin: 0; font-size: 0.75rem; text-transform: none; letter-spacing: 0; font-weight: 500; }

  .style-panel-color { width: 40px; height: 28px; padding: 0; border-radius: 6px; }

  .style-panel-help { font-size: 0.7rem; color: var(--ksg-gray); padding-top: 2px; }

  .manage-search--wide { max-width: 320px; }

  .empty-link { color: var(--ksg-gold); cursor: pointer; }

  .bulk-code { font-size: 0.8rem; color: var(--ksg-gray); font-family: 'DM Mono', monospace; }

  .bulk-status { margin-top: 12px; font-size: 0.85rem; color: var(--ksg-gray); }

  .bulk-inline { margin-top: 16px; }

  .bulk-actions-row { padding: 16px; border-top: 1px solid var(--ksg-light); display: flex; gap: 10px; }

  .page-header-actions { display: flex; gap: 8px; }

  .settings-note { margin-top: 12px; font-size: 0.8rem; color: var(--ksg-gray); }

  .settings-action-btn { margin-bottom: 8px; display: block; width: 100%; }

  .stats-grid--compact { margin-bottom: 24px; }

  .logs-toolbar { display: flex; gap: 8px; align-items: center; }

  .logs-search { padding: 8px 12px; border-radius: 6px; border: 1px solid var(--ksg-light); width: 200px; font-size: 0.85rem; }

  .modal--wide { width: 700px; }

  .modal-body--centered { display: flex; flex-direction: column; align-items: center; gap: 16px; }

  .modal-actions--centered { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; }

  .modal--dark { background: var(--ksg-navy); color: #ffffff; }

  .modal-header--dark { background: var(--ksg-gold); border-bottom-color: var(--ksg-gold); color: var(--ksg-dark); }

  .modal-close--dark { color: var(--ksg-dark); }

  .modal-form-group { margin-bottom: 16px; }

  .modal-form-label--dark { font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 6px; color: var(--ksg-gold); }

  .modal-form-input--dark { width: 100%; padding: 10px 13px; border: 2px solid var(--ksg-gold); border-radius: 8px; font-size: 0.9rem; outline: none; font-family: 'DM Sans', sans-serif; background: #000000; color: #ffffff; }

  .modal-form-input--dark:focus { border-color: var(--ksg-gold-light); box-shadow: 0 0 0 3px rgba(201,168,76,0.2); }

  .modal-footer--dark { border-top-color: var(--ksg-gold); background: var(--ksg-navy); }

  .modal--dark .modal-body { background: #000000; }

  .modal-copy { font-size: 0.9rem; color: var(--ksg-gray); }

  .modal--compact { width: 400px; }

  .hidden { display: none !important; }


  /* ─── QUICK ACTIONS ─── */

  .quick-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

  .qa-btn {

    padding: 14px; border-radius: 10px; border: 1px solid var(--ksg-light);

    background: var(--ksg-light); cursor: pointer;

    display: flex; align-items: center; gap: 10px;

    font-size: 0.83rem; font-weight: 500; color: var(--ksg-dark);

    transition: all 0.2s; font-family: 'DM Sans', sans-serif;

    text-align: left;

  }

  .qa-btn:hover { background: var(--ksg-dark); color: white; border-color: var(--ksg-dark); }

  .qa-btn .qa-icon { font-size: 1.2rem; }


  /* ─── RECENT TAGS TABLE ─── */

  .data-table { width: 100%; border-collapse: collapse; }

  .data-table th { text-align: left; padding: 10px 14px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: var(--ksg-gray); border-bottom: 1px solid var(--ksg-light); }

  .data-table td { padding: 12px 14px; font-size: 0.86rem; color: var(--ksg-dark); border-bottom: 1px solid rgba(0,0,0,0.04); }

  .data-table tr:last-child td { border-bottom: none; }

  .data-table tr:hover td { background: var(--ksg-light); }

  .badge {

    display: inline-block; padding: 3px 10px; border-radius: 20px;

    font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;

  }

  .badge-staff { background: rgba(26,58,107,0.1); color: var(--ksg-blue); }

  .badge-intern { background: rgba(46,204,113,0.1); color: #27AE60; }

  .badge-visitor { background: rgba(243,156,18,0.1); color: var(--ksg-warning); }

  .badge-attachee { background: rgba(155,89,182,0.1); color: #8E44AD; }

  .badge-student { background: rgba(52,152,219,0.1); color: #2980B9; }

  .badge-trainer { background: rgba(231,76,60,0.1); color: var(--ksg-danger); }

  .badge-status-active { background: rgba(46,204,113,0.1); color: #1E8449; }

  .badge-status-inactive { background: rgba(243,156,18,0.1); color: #B7770D; }

  .badge-status-expired { background: rgba(231,76,60,0.1); color: #922B21; }


  /* ─── GENERATE TAG PAGE ─── */

  .gen-layout { display: grid; grid-template-columns: 320px 1fr; gap: 24px; align-items: start; }

  .gen-form { padding: 18px 20px; }

  .gen-form .form-group { margin-bottom: 12px; }

  .gen-form .form-row { gap: 12px; }

  .gen-form label { font-size: 0.72rem; margin-bottom: 4px; letter-spacing: 0.3px; }

  .gen-form input, .gen-form select { padding: 8px 10px; font-size: 0.82rem; border-radius: 6px; }

  .form-card .card-header { padding: 12px 18px; }

  .form-card .card-title { font-size: 0.9rem; }

  .form-actions .btn { padding: 8px 14px; font-size: 0.8rem; }

  .preview-body { padding: 32px; }

  .form-card { background: var(--ksg-white); border-radius: var(--radius); box-shadow: var(--shadow); }

  .form-card .card-header { background: var(--ksg-dark); }

  .form-card .card-title { color: var(--ksg-white); }

  .gen-form { padding: 28px; }

  .gen-form .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }

  .gen-form .form-group { margin-bottom: 20px; }

  .gen-form label { display: block; font-size: 0.82rem; font-weight: 600; color: var(--ksg-dark); margin-bottom: 7px; text-transform: uppercase; letter-spacing: 0.5px; }

  .gen-form input, .gen-form select {

    width: 100%; padding: 11px 14px;

    border: 1.5px solid var(--ksg-light);

    border-radius: 8px;

    color: var(--ksg-dark); font-size: 0.9rem;

    font-family: 'DM Sans', sans-serif;

    outline: none; transition: border-color 0.2s;

    background: var(--ksg-white);

  }

  .gen-form input:focus, .gen-form select:focus { border-color: var(--ksg-gold); }

  .gen-form input.error { border-color: var(--ksg-danger); }

  .field-error { color: var(--ksg-danger); font-size: 0.77rem; margin-top: 4px; }

  .form-actions { display: flex; gap: 10px; margin-top: 8px; }

  .btn { padding: 11px 22px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.88rem; font-weight: 600; font-family: 'DM Sans', sans-serif; transition: all 0.2s; display: inline-flex; align-items: center; gap: 7px; }

  .btn-gold { background: linear-gradient(135deg, var(--ksg-gold), var(--ksg-gold-light)); color: var(--ksg-dark); }

  .btn-gold:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(201,168,76,0.35); }

  .btn-dark { background: var(--ksg-dark); color: white; }

  .btn-dark:hover { background: var(--ksg-navy); }

  .btn-success { background: #2ecc71; color: white; }

  .btn-success:hover { background: #27ae60; transform: translateY(-1px); }

  .btn-outline { background: transparent; border: 1.5px solid var(--ksg-light); color: var(--ksg-gray); }

  .btn-outline:hover { border-color: var(--ksg-dark); color: var(--ksg-dark); }

  .btn-danger { background: var(--ksg-danger); color: white; }

  .btn-sm { padding: 7px 14px; font-size: 0.8rem; }

  .btn-icon { width: 34px; height: 34px; padding: 0; justify-content: center; border-radius: 8px; }


  /* ─── TAG PREVIEW ─── */

  .preview-card { background: var(--ksg-white); border-radius: var(--radius); box-shadow: var(--shadow); position: sticky; top: 88px; }

  .preview-card .card-header { background: linear-gradient(135deg, var(--ksg-dark), var(--ksg-blue)); }

  .preview-card .card-title { color: var(--ksg-white); }

  .preview-body { padding: 24px; display: flex; flex-direction: column; align-items: center; gap: 16px; }

  .tag-preview-wrap { width: 100%; display: flex; justify-content: center; }


  /* ─── ID TAG DESIGN — EXACT KSG REPLICA ─── */

  .id-tag {

    width: 360px;

    height: 225px;

    background: #ffffff;

    border-radius: 4px;

    overflow: hidden;

    box-shadow: 0 8px 32px rgba(0,0,0,0.18);

    border: 1px solid rgba(0,0,0,0.08);

    position: relative;

    font-family: Arial, sans-serif;

  }

  .id-tag .wave-svg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }

  .id-tag .tag-content { position: relative; z-index: 2; width: 100%; height: 100%; }

  .id-tag .tag-coa { position: absolute; top: 7%; left: 6%; width: 17%; }

  .id-tag .tag-coa img { width: 100%; display: block; }

  .id-tag .tag-ksg { position: absolute; top: 8%; right: 5%; width: 24%; }

  .id-tag .tag-ksg img { width: 100%; display: block; }

  .id-tag .tag-org-name {

    position: absolute; top: 36%; left: 0; right: 0; text-align: center;

    font-family: Arial, sans-serif; font-weight: 800; font-size: 0.62rem;

    color: #7F622C; letter-spacing: 0.5px;

  }

  .id-tag .tag-name {

    position: absolute; top: 44%; left: 0; right: 0; text-align: center;

    font-family: Georgia, 'Times New Roman', serif; font-weight: 700; font-size: 1.18rem;

    color: #000; line-height: 1.1; padding: 0 6px;

  }

  .id-tag .tag-position {

    position: absolute; top: 61%; left: 0; right: 0; text-align: center;

    font-family: Georgia, 'Times New Roman', serif; font-weight: 700; font-size: 0.82rem;

    color: #000; text-transform: uppercase; letter-spacing: 0.5px;

  }

  .id-tag .tag-pno {

    position: absolute; top: 55%; left: 0; right: 0; text-align: center;

    font-family: Georgia, 'Times New Roman', serif; font-weight: 700; font-size: 0.75rem;

    color: #000; letter-spacing: 0.3px;

  }

  .id-tag .tag-idno {

    position: absolute; top: 61%; left: 0; right: 0; text-align: center;

    font-family: Georgia, 'Times New Roman', serif; font-weight: 700; font-size: 0.75rem;

    color: #000; letter-spacing: 0.3px;

  }

  .id-tag .tag-dept {

    position: absolute; top: 76%; left: 0; right: 0; text-align: center;

    font-family: Georgia, 'Times New Roman', serif; font-weight: 700; font-size: 0.96rem;

    color: #000; text-transform: uppercase; letter-spacing: 0.5px; padding: 0 8px;

  }

  .id-tag .tag-category-badge {

    display: none;

  }

  .id-tag .tag-meta-strip {

    display: none;

  }

  .id-tag .tag-ref, .id-tag .tag-date { display: none; }


  .preview-actions { display: flex; flex-wrap: wrap; gap: 8px; width: 100%; justify-content: center; }


  /* ─── MANAGE TAGS PAGE ─── */

  .manage-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }

  .search-box {

    display: flex; align-items: center; gap: 8px;

    background: white; border: 1.5px solid var(--ksg-light);

    border-radius: 8px; padding: 9px 14px; flex: 1; min-width: 200px;

  }

  .search-box input { border: none; outline: none; font-size: 0.87rem; width: 100%; font-family: 'DM Sans', sans-serif; }

  .filter-select {

    padding: 10px 14px; border: 1.5px solid var(--ksg-light);

    border-radius: 8px; background: white; font-size: 0.88rem;

    outline: none; cursor: pointer; font-family: 'DM Sans', sans-serif; color: var(--ksg-dark);

  }

  .table-card { background: white; border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }

  .table-header { padding: 18px 24px; border-bottom: 1px solid var(--ksg-light); display: flex; align-items: center; justify-content: space-between; }

  .table-title { font-weight: 600; color: var(--ksg-dark); font-size: 0.95rem; }

  .table-count { color: var(--ksg-gray); font-size: 0.82rem; }

  .table-wrap { overflow-x: auto; }

  .action-btns { display: flex; gap: 5px; }


  /* ─── PAGINATION ─── */

  .pagination { display: flex; gap: 4px; justify-content: center; padding: 20px; }

  .pg-btn { width: 34px; height: 34px; border: 1.5px solid var(--ksg-light); background: white; border-radius: 7px; cursor: pointer; font-size: 0.85rem; color: var(--ksg-dark); font-family: 'DM Sans', sans-serif; transition: all 0.2s; }

  .pg-btn:hover, .pg-btn.active { background: var(--ksg-dark); color: white; border-color: var(--ksg-dark); }


  /* ─── BULK UPLOAD ─── */

  .bulk-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

  .drop-zone {

    border: 2px dashed var(--ksg-gold);

    border-radius: 12px; padding: 40px 24px;

    text-align: center; cursor: pointer;

    background: rgba(201,168,76,0.03);

    transition: all 0.2s;

  }

  .drop-zone:hover, .drop-zone.dragover { background: rgba(201,168,76,0.08); border-color: var(--ksg-gold-light); }

  .drop-icon { font-size: 2.5rem; margin-bottom: 12px; }

  .drop-title { font-size: 1rem; font-weight: 600; margin-bottom: 6px; }

  .drop-hint { font-size: 0.82rem; color: var(--ksg-gray); }

  .bulk-preview-table { max-height: 300px; overflow-y: auto; }

  .progress-bar { height: 6px; background: var(--ksg-light); border-radius: 3px; overflow: hidden; margin-top: 12px; }

  .progress-fill { height: 100%; background: linear-gradient(90deg, var(--ksg-gold), var(--ksg-gold-light)); border-radius: 3px; transition: width 0.3s; }


  /* ─── REPORTS ─── */

  .reports-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 24px; }

  .report-card { background: white; border-radius: var(--radius); box-shadow: var(--shadow); padding: 24px; }

  .report-card h3 { font-family: 'Playfair Display', serif; font-size: 0.95rem; margin-bottom: 16px; color: var(--ksg-dark); }

  .chart-bar-wrap { display: flex; flex-direction: column; gap: 8px; }

  .chart-bar-item { display: flex; align-items: center; gap: 10px; }

  .chart-bar-label { font-size: 0.8rem; width: 80px; color: var(--ksg-dark); }

  .chart-bar-track { flex: 1; height: 10px; background: var(--ksg-light); border-radius: 5px; overflow: hidden; }

  .chart-bar-fill { height: 100%; border-radius: 5px; transition: width 0.6s ease; }

  .chart-bar-val { font-size: 0.78rem; color: var(--ksg-gray); width: 28px; text-align: right; }


  /* ─── SETTINGS ─── */

  .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

  .settings-card { background: white; border-radius: var(--radius); box-shadow: var(--shadow); }

  .settings-form { padding: 24px; }

  .settings-form .form-group { margin-bottom: 18px; }

  .settings-form label { display: block; font-size: 0.82rem; font-weight: 600; color: var(--ksg-dark); margin-bottom: 6px; }

  .settings-form input, .settings-form select, .settings-form textarea {

    width: 100%; padding: 10px 13px; border: 1.5px solid var(--ksg-light);

    border-radius: 8px; font-size: 0.87rem; outline: none; font-family: 'DM Sans', sans-serif;

    color: var(--ksg-dark); transition: border-color 0.2s;

  }

  .settings-form input:focus, .settings-form textarea:focus { border-color: var(--ksg-gold); }

  .toggle { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--ksg-light); }

  .toggle:last-child { border-bottom: none; }

  .toggle-label { font-size: 0.88rem; color: var(--ksg-dark); }

  .toggle-switch { width: 44px; height: 24px; background: var(--ksg-light); border-radius: 12px; cursor: pointer; position: relative; transition: background 0.2s; }

  .toggle-switch.on { background: var(--ksg-gold); }

  .toggle-switch::after { content: ''; position: absolute; top: 3px; left: 3px; width: 18px; height: 18px; background: white; border-radius: 50%; transition: left 0.2s; box-shadow: 0 1px 4px rgba(0,0,0,0.2); }

  .toggle-switch.on::after { left: 23px; }


  /* ─── ACTIVITY LOG ─── */

  .log-item { display: flex; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--ksg-light); }

  .log-item:last-child { border-bottom: none; }

  .log-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--ksg-gold); margin-top: 6px; flex-shrink: 0; }

  .log-text { font-size: 0.84rem; color: var(--ksg-dark); }

  .log-time { font-size: 0.75rem; color: var(--ksg-gray); margin-top: 2px; }


  /* ─── MODAL ─── */

  .modal-overlay {

    position: fixed; inset: 0; background: rgba(10,22,40,0.6);

    z-index: 999; display: none; align-items: center; justify-content: center;

    -webkit-backdrop-filter: blur(4px);

    backdrop-filter: blur(4px);

  }

  .modal-overlay.open { display: flex; }

  .modal {

    background: white; border-radius: 16px;

    box-shadow: var(--shadow-lg); width: min(980px, 96vw);

    max-width: 96vw; max-height: 92vh; overflow-y: auto;

    animation: modalIn 0.2s ease;

  }

  @keyframes modalIn { from { opacity:0; transform: scale(0.94) translateY(10px); } }

  .modal-header { padding: 22px 26px; border-bottom: 1px solid var(--ksg-light); display: flex; align-items: center; justify-content: space-between; }

  .modal-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; }

  .modal-close { background: none; border: none; cursor: pointer; font-size: 1.2rem; color: var(--ksg-gray); }

  .modal-body { padding: 24px 26px; }

  .modal-body--split {

    display: grid;

    grid-template-columns: 1fr;

    gap: 24px;

    align-items: start;

  }

  .modal-preview-shell {

    display: flex;

    flex-direction: column;

    justify-content: center;

    align-items: center;

    padding: 8px 0;

    gap: 16px;

  }

  .modal-preview-shell .id-tag {

    width: min(100%, 520px);

    height: auto;

    aspect-ratio: 526 / 325;

    transform: scale(1.05);

    transform-origin: center;

  }

  .modal-form-stack {

    display: flex;

    flex-direction: column;

    gap: 12px;

  }

  .modal-footer { padding: 16px 26px; border-top: 1px solid var(--ksg-light); display: flex; gap: 10px; justify-content: flex-end; }


  /* ─── TOAST ─── */

  #toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }

  .toast {

    background: var(--ksg-dark); color: white; padding: 12px 18px;

    border-radius: 10px; font-size: 0.86rem; min-width: 260px;

    display: flex; align-items: center; gap: 10px;

    animation: toastIn 0.3s ease; box-shadow: var(--shadow-lg);

    border-left: 4px solid var(--ksg-gold);

  }

  .toast.success { border-left-color: var(--ksg-success); }

  .toast.error { border-left-color: var(--ksg-danger); }

  @keyframes toastIn { from { opacity:0; transform: translateX(20px); } }


  /* ─── RESPONSIVE ─── */

  @media (max-width: 1024px) {

    .stats-grid { grid-template-columns: repeat(2,1fr); }

    .dash-grid { grid-template-columns: 1fr; }

    .gen-layout { grid-template-columns: 1fr; }

    .bulk-layout { grid-template-columns: 1fr; }

    .settings-grid { grid-template-columns: 1fr; }

    .reports-grid { grid-template-columns: 1fr 1fr; }

  }

  @media (max-width: 768px) {

    .sidebar { transform: translateX(-100%); }

    .sidebar.open { transform: translateX(0); }

    .main-content { margin-left: 0; }

    .page-content { padding: 16px; }

    .topbar { padding: 0 16px; }

    .hamburger { display: flex; }

    .topbar-search { display: none; }

    .stats-grid { grid-template-columns: 1fr 1fr; gap: 12px; }

    .gen-form .form-row { grid-template-columns: 1fr; }

    .reports-grid { grid-template-columns: 1fr; }

    

    /* Footer mobile */

    footer { margin-left: 0 !important; }

    

    /* Auth screen mobile */

    .auth-card { padding: 32px 24px; width: 90vw; }

    .auth-logo h1 { font-size: 1.3rem; }

    .auth-logo .crest { width: 60px; height: 60px; font-size: 28px; }

    

    /* Tag preview mobile */

    .id-tag { 

      width: 100% !important; 

      height: auto !important; 

      aspect-ratio: 1.62 / 1;

      max-width: 400px;

    }

    .tag-preview-container { overflow-x: auto; }

    

    /* Form inputs mobile */

    input, select, textarea { font-size: 16px !important; }

    .btn { min-height: 44px; }

    

    /* Tables mobile */

    .data-table { font-size: 14px; }

    .data-table th, .data-table td { padding: 8px 6px; }

  }

  @media (max-width: 480px) {

    .stats-grid { grid-template-columns: 1fr; }

    .auth-card { padding: 24px 20px; width: 95vw; }

    .auth-logo h1 { font-size: 1.1rem; }

    .auth-logo p { font-size: 0.7rem; }

    

    /* Smaller tag preview */

    .id-tag { max-width: 100%; }

    

    /* Compact buttons */

    .btn { padding: 10px 16px; font-size: 14px; }

    .btn-sm { padding: 6px 12px; font-size: 12px; }

    

    /* Compact cards */

    .card { padding: 16px; }

    .card-header { padding: 12px 16px; }

    

    /* Navigation */

    .nav-item { padding: 12px 16px; font-size: 14px; }

    .nav-icon { font-size: 18px; }

    

    /* Topbar */

    .topbar { height: 56px; }

    .topbar-title { font-size: 16px; }

    

    /* Forms */

    .form-group label { font-size: 13px; }

    .form-row { gap: 12px; }

    

    /* Tables */

    .data-table-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; }

    .data-table { min-width: 600px; }

    

    /* Modals */

    .modal-content { width: 95vw; max-height: 90vh; overflow-y: auto; }

    

    /* Toast notifications */

    .toast { font-size: 14px; padding: 12px 16px; }

  }

  

  /* Extra small devices (very old phones) */

  @media (max-width: 360px) {

    .auth-card { padding: 20px 16px; }

    .auth-logo h1 { font-size: 1rem; }

    .stats-grid { gap: 8px; }

    .card { padding: 12px; }

  }


  /* ─── MISC ─── */

  .empty-state { text-align: center; padding: 48px 24px; color: var(--ksg-gray); }

  .empty-state .empty-icon { font-size: 2.5rem; margin-bottom: 10px; }

  .empty-state p { font-size: 0.9rem; }

  .divider { height: 1px; background: var(--ksg-light); margin: 20px 0; }

  .page-header { margin-bottom: 24px; }

  .page-header h2 { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--ksg-dark); }

  .page-header p { color: var(--ksg-gray); font-size: 0.88rem; margin-top: 4px; }

  .supabase-note { background: linear-gradient(135deg, rgba(10,22,40,0.04), rgba(201,168,76,0.06)); border: 1px solid rgba(201,168,76,0.2); border-radius: 10px; padding: 14px 18px; margin-bottom: 24px; font-size: 0.82rem; color: var(--ksg-gray); }

  .supabase-note strong { color: var(--ksg-dark); }

  .overlay { position: fixed; inset: 0; background: rgba(10,22,40,0.4); z-index: 90; display: none; }

  .overlay.open { display: block; }


  /* ─── OVERRIDE: use first-editor template.png display ─── */

  .id-tag {

    width: 526px !important;

    height: 325px !important;

    background: url('template.png') no-repeat center/100% 100% !important;

    border: none !important;

    box-shadow: 0 8px 32px rgba(0,0,0,0.18) !important;

    font-family: Arial, sans-serif !important;

  }

  .id-tag .wave-svg,

  .id-tag .tag-coa,

  .id-tag .tag-ksg { display: none !important; }

  .id-tag .tag-org-name {

    top: 132px !important; left: 284px !important; right: auto !important;

    transform: translate(-50%, -50%);

    font-family: Arial, sans-serif !important;

    font-size: 22px !important; font-weight: 700 !important;

    letter-spacing: 1.5px !important; color: #A2A825 !important;

    white-space: nowrap;

  }

  .id-tag .tag-name {

    top: 183px !important; left: 257px !important; right: auto !important;

    transform: translate(-50%, -50%);

    font-family: "Times New Roman", Times, serif !important;

    font-size: 30px !important; font-weight: 800 !important;

    letter-spacing: 0.5px !important; color: #000 !important;

    padding: 0 !important; white-space: nowrap;

  }

  .id-tag .tag-position {

    top: 226px !important; left: 260px !important; right: auto !important;

    transform: translate(-50%, -50%);

    font-family: "Times New Roman", Times, serif !important;

    font-size: 24px !important; font-weight: 700 !important;

    letter-spacing: 0.5px !important; color: #000 !important;

    white-space: nowrap;

  }

  .id-tag .tag-dept {

    top: 269px !important; left: 258px !important; right: auto !important;

    transform: translate(-50%, -50%);

    font-family: "Times New Roman", Times, serif !important;

    font-size: 25px !important; font-weight: 700 !important;

    letter-spacing: 0.5px !important; color: #000 !important;

    padding: 0 !important; white-space: nowrap;

  }

</style>

</head>

<body>



<!-- ════════════════════ AUTH SCREEN ════════════════════ -->

<div id="auth-screen">

  <div class="auth-card">

    <div class="auth-logo">

      <div class="crest">🏛️</div>

      <h1>Kenya School of Government</h1>

      <p>EMBU CAMPUS · Tag Generator</p>

    </div>

    <div class="auth-tabs">

      <button class="auth-tab active" onclick="switchAuthTab('login')">Sign In</button>

      <button class="auth-tab" onclick="switchAuthTab('register')">Register</button>

    </div>



    <!-- LOGIN -->

    <div class="auth-form active" id="form-login">

      <div id="login-alert"></div>

      <div class="form-group">

        <label>Email Address</label>

        <input type="email" id="login-email" placeholder="admin@ksg.go.ke">

      </div>

      <div class="form-group">

        <label>Password</label>

        <input type="password" id="login-pass" placeholder="••••••••">

      </div>

      <button class="btn-primary" onclick="doLogin()">Sign In to Dashboard</button>

      <p class="auth-note"><a onclick="switchAuthTab('reset')">Forgot your password?</a></p>

    </div>



    <!-- REGISTER -->

    <div class="auth-form" id="form-register">

      <div id="reg-alert"></div>

      <div class="form-group">

        <label>Full Name</label>

        <input type="text" id="reg-name" placeholder="John Doe">

      </div>

      <div class="form-group">

        <label>Email Address</label>

        <input type="email" id="reg-email" placeholder="admin@ksg.go.ke">

      </div>

      <div class="form-group">

        <label>Password</label>

        <input type="password" id="reg-pass" placeholder="Min 8 characters">

      </div>

      <button class="btn-primary" onclick="doRegister()">Request Account</button>

      <p class="auth-note">Your account will be pending approval by a superadmin.</p>

    </div>



    <!-- RESET -->

    <div class="auth-form" id="form-reset">

      <div id="reset-alert"></div>

      <div class="form-group">

        <label>Registered Email</label>

        <input type="email" id="reset-email" placeholder="admin@ksg.go.ke">

      </div>

      <button class="btn-primary" onclick="doReset()">Send Reset Link</button>

      <p class="auth-note"><a onclick="switchAuthTab('login')">← Back to Sign In</a></p>

    </div>

  </div>

</div>



<!-- ════════════════════ APP ════════════════════ -->

<div id="app">

  <div class="overlay" id="sidebar-overlay" onclick="closeSidebar()"></div>

  <div class="app-layout">



    <!-- SIDEBAR -->

    <aside class="sidebar" id="sidebar">

      <div class="sidebar-logo">

        <div class="logo-mark">🏛️</div>

        <h2>KSG Tag System</h2>

        <span>EMBU CAMPUS</span>

      </div>

      <nav class="sidebar-nav">

        <div class="nav-section">

          <div class="nav-section-label">Main</div>

          <button class="nav-item active" onclick="gotoPage('dashboard', this)"><span class="nav-icon">📊</span> Dashboard</button>

          <button class="nav-item" onclick="gotoPage('generate', this)"><span class="nav-icon">🏷️</span> Generate Tag</button>

          <button class="nav-item" onclick="gotoPage('manage', this)"><span class="nav-icon">📋</span> Manage Tags <span class="nav-badge" id="nav-tag-count">0</span></button>

        </div>

        <div class="nav-section">

          <div class="nav-section-label">Tools</div>

          <button class="nav-item" onclick="gotoPage('bulk', this)"><span class="nav-icon">📤</span> Bulk Generation</button>

          <button class="nav-item" onclick="gotoPage('reports', this)"><span class="nav-icon">📈</span> Reports</button>

        </div>

        <div class="nav-section">

          <div class="nav-section-label">System</div>

          <button class="nav-item" onclick="gotoPage('settings', this)"><span class="nav-icon">⚙️</span> Settings</button>

          <button class="nav-item" onclick="gotoPage('logs', this)"><span class="nav-icon">📝</span> Activity Logs</button>

        </div>

      </nav>

      <div class="sidebar-footer">

        <div class="user-info">

          <div class="user-avatar" id="user-av">A</div>

          <div class="user-details">

            <div class="user-name" id="user-name-disp">Admin User</div>

            <div class="user-role" id="user-role-disp">Administrator</div>

          </div>

          <button class="btn-logout" onclick="doLogout()" title="Logout">🚪</button>

        </div>

      </div>

    </aside>



    <!-- MAIN -->

    <div class="main-content">

      <header class="topbar">

        <button class="hamburger topbar-btn" onclick="toggleSidebar()">☰</button>

        <div class="topbar-title" id="topbar-title">Dashboard</div>

        <div class="topbar-search">

          <span>🔍</span>

          <input type="text" placeholder="Search tags, people…" id="global-search" oninput="globalSearch(this.value)">

        </div>

        <div class="topbar-actions">

          <button class="topbar-btn" onclick="toggleDark()" id="dark-btn" title="Dark mode">🌙</button>

          <button class="topbar-btn" onclick="gotoPage('generate', document.querySelectorAll('.nav-item')[1])">➕</button>

          <button class="topbar-btn" onclick="showNotif()" title="Notifications">🔔<span class="notif-dot"></span></button>

        </div>

      </header>



      <div class="page-content">



        <!-- ── DASHBOARD ── -->

        <div class="page active" id="page-dashboard">

          <div class="stats-grid">

            <div class="stat-card gold">

              <div class="stat-icon">🏷️</div>

              <div class="stat-value" id="stat-total">0</div>

              <div class="stat-label">Total Tags Generated</div>

              <div class="stat-change">↑ 12% this month</div>

            </div>

            <div class="stat-card blue">

              <div class="stat-icon">👥</div>

              <div class="stat-value" id="stat-users">1</div>

              <div class="stat-label">Active Users</div>

              <div class="stat-change">↑ 3 new this week</div>

            </div>

            <div class="stat-card green">

              <div class="stat-icon">✅</div>

              <div class="stat-value" id="stat-active">0</div>

              <div class="stat-label">Active Tags</div>

              <div class="stat-change">All verified</div>

            </div>

            <div class="stat-card red">

              <div class="stat-icon">📅</div>

              <div class="stat-value" id="stat-today">0</div>

              <div class="stat-label">Generated Today</div>

              <div class="stat-change">Current session</div>

            </div>

          </div>

          <div class="dash-grid">

            <div class="card">

              <div class="card-header">

                <span class="card-title">Recently Generated Tags</span>

                <button class="btn btn-sm btn-outline" onclick="gotoPage('manage',document.querySelectorAll('.nav-item')[2])">View All</button>

              </div>

              <div class="card-body card-body--flush">

                <table class="data-table">

                  <thead><tr><th>Name</th><th>Category</th><th>Department</th><th>Date</th></tr></thead>

                  <tbody id="recent-tags-body">

                    <tr><td colspan="4"><div class="empty-state"><div class="empty-icon">🏷️</div><p>No tags generated yet</p></div></td></tr>

                  </tbody>

                </table>

              </div>

            </div>

            <div class="card">

              <div class="card-header"><span class="card-title">Quick Actions</span></div>

              <div class="card-body">

                <div class="quick-actions">

                  <button class="qa-btn" onclick="gotoPage('generate',document.querySelectorAll('.nav-item')[1])"><span class="qa-icon">🏷️</span>New Tag</button>

                  <button class="qa-btn" onclick="gotoPage('bulk',document.querySelectorAll('.nav-item')[3])"><span class="qa-icon">📤</span>Bulk Upload</button>

                  <button class="qa-btn" onclick="gotoPage('manage',document.querySelectorAll('.nav-item')[2])"><span class="qa-icon">📋</span>All Tags</button>

                  <button class="qa-btn" onclick="gotoPage('reports',document.querySelectorAll('.nav-item')[4])"><span class="qa-icon">📈</span>Reports</button>

                  <button class="qa-btn" onclick="exportAll()"><span class="qa-icon">📥</span>Export CSV</button>

                  <button class="qa-btn" onclick="gotoPage('settings',document.querySelectorAll('.nav-item')[5])"><span class="qa-icon">⚙️</span>Settings</button>

                </div>

                <div class="divider"></div>

                <div class="card-title card-title--small">Category Breakdown</div>

                <div class="chart-bar-wrap" id="dash-category-chart"></div>

              </div>

            </div>

          </div>

        </div>



        <!-- ── GENERATE TAG ── -->

        <div class="page" id="page-generate">

          <div class="page-header">

            <h2>Generate Identification Tag</h2>

            <p>Fill in the details below to generate and print an official KSG ID tag</p>

          </div>

          <div class="gen-layout">

            <div class="form-card card">

              <div class="card-header">

                <span class="card-title">Tag Information</span>

                <span class="text-muted-light">All fields required</span>

              </div>

              <div class="gen-form">

                <div class="form-row">

                  <div class="form-group">

                    <label class="modal-form-label--dark">Category</label>

                    <select id="f-cat" onchange="updatePreview(); toggleStaffFields()" class="modal-form-input--dark">

                      <option value="">Select Category</option>

                      <option value="Staff">Staff</option>

                      <option value="Attachee">Attachee</option>

                      <option value="Intern">Intern</option>

                      <option value="Visitor">Visitor</option>

                      <option value="Student">Student</option>

                      <option value="Trainer">Trainer</option>

                    </select>

                    <div class="field-error" id="err-cat"></div>

                  </div>

                  <select id="f-status" class="field-hidden">

                    <option value="Active">Active</option>

                    <option value="Inactive">Inactive</option>

                    <option value="Expired">Expired</option>

                  </select>

                </div>

                <div class="form-row">

                  <div class="form-group">

                    <label class="modal-form-label--dark">Full Name *</label>

                    <input type="text" id="f-name" placeholder="e.g. John Kamau Mwangi" oninput="updatePreview()" class="modal-form-input--dark">

                    <div class="field-error" id="err-name"></div>

                  </div>

                  <input type="hidden" id="f-idnum" value="">

                  <div class="field-error field-hidden" id="err-idnum"></div>

                </div>

                <div class="form-row" id="staff-fields-row" style="display: none;">

                  <div class="form-group">

                    <label class="modal-form-label--dark">P/No</label>

                    <input type="text" id="f-pno" placeholder="e.g. 12345" oninput="updatePreview()" class="modal-form-input--dark">

                    <div class="field-error" id="err-pno"></div>

                  </div>

                  <div class="form-group">

                    <label class="modal-form-label--dark">ID/No</label>

                    <input type="text" id="f-idno" placeholder="e.g. 12345678" oninput="updatePreview()" class="modal-form-input--dark">

                    <div class="field-error" id="err-idno"></div>

                  </div>

                </div>

                <div class="form-row">

                  <div class="form-group">

                    <label class="modal-form-label--dark">Department *</label>

                    <select id="f-dept" onchange="updatePreview()" class="modal-form-input--dark">

                      <option value="">Select Department</option>

                      <option>ICT Department</option>

                      <option>Finance & Accounts</option>

                      <option>Human Resource</option>

                      <option>Administration</option>

                      <option>Academic Affairs</option>

                      <option>Research & Consultancy</option>

                      <option>Security</option>

                      <option>Facilities Management</option>

                      <option>Library Services</option>

                      <option>Communications</option>

                    </select>

                    <div class="field-error" id="err-dept"></div>

                  </div>

                  <input type="hidden" id="f-position" value="">

                  <div class="field-error field-hidden" id="err-position"></div>

                </div>

                <div class="form-actions">

                  <button class="btn btn-success" onclick="saveTagOnly()">💾 Save Tag</button>

                  <button class="btn btn-outline" onclick="clearForm()">✕ Clear</button>

                </div>



                <!-- ─── Per-field text styling ─── -->

                <div class="style-panel">

                  <div class="style-panel-header">

                    <label class="style-panel-title">Edit Text Styling</label>

                    <select id="sp-target" class="style-panel-select style-panel-select--compact">

                      <option value="pt-name">Full Name</option>

                      <option value="pt-dept">Department</option>

                      <option value="pt-pno">P/No</option>

                      <option value="pt-idno">ID/No</option>

                      <option value="pt-orgname">Institution</option>

                    </select>

                  </div>

                  <div class="style-panel-controls">

                    <div><div class="style-panel-heading">FONT FAMILY</div>

                      <select id="sp-ff" class="style-panel-select style-panel-select--full">

                        <option>Arial</option><option>Helvetica</option><option>Times New Roman</option>

                        <option>Georgia</option><option>Courier New</option><option>Verdana</option>

                        <option>Tahoma</option><option>Trebuchet MS</option>

                      </select></div>

                    <div><div class="style-panel-row"><span class="style-panel-label">FONT SIZE</span><span id="sp-size-v">24px</span></div>

                      <input type="range" id="sp-size" min="8" max="80" value="24" class="style-panel-range"></div>

                    <div><div class="style-panel-row"><span class="style-panel-label">WEIGHT</span><span id="sp-w-v">700</span></div>

                      <input type="range" id="sp-w" min="100" max="900" step="100" value="700" class="style-panel-range"></div>

                    <div><div class="style-panel-row"><span class="style-panel-label">LETTER SPACING</span><span id="sp-ls-v">0.5px</span></div>

                      <input type="range" id="sp-ls" min="-2" max="10" step="0.1" value="0.5" class="style-panel-range"></div>

                    <div><div class="style-panel-row"><span class="style-panel-label">TOP</span><span id="sp-top-v">183px</span></div>

                      <input type="range" id="sp-top" min="0" max="325" value="183" class="style-panel-range"></div>

                    <div><div class="style-panel-row"><span class="style-panel-label">LEFT</span><span id="sp-left-v">257px</span></div>

                      <input type="range" id="sp-left" min="0" max="526" value="257" class="style-panel-range"></div>

                    <div class="style-panel-inline">

                      <label class="style-panel-check">

                        <input type="checkbox" id="sp-bg" class="style-panel-checkbox"> White backdrop

                      </label>

                      <label class="style-panel-check">

                        Color <input type="color" id="sp-color" value="#000000" class="style-panel-color">

                      </label>

                    </div>

                    <div class="style-panel-help">Tip: drag text directly on the preview.</div>

                  </div>

                </div>

              </div>

            </div>



            <!-- LIVE PREVIEW -->

            <div class="preview-card card">

              <div class="card-header">

                <span class="card-title">Live Tag Preview</span>

              </div>

              <div class="preview-body">

                <div class="tag-preview-wrap">

                  <div class="id-tag" id="id-tag">

                    <!-- wave background injected by JS into #wave-bg-slot -->

                    <div id="wave-bg-slot"></div>

                    <div class="tag-content">

                      <div class="tag-coa"><img src="" id="pt-coa-img" alt="Kenya Coat of Arms"></div>

                      <div class="tag-ksg"><img src="" id="pt-ksg-img" alt="KSG Logo"></div>

                      <div class="tag-org-name" id="pt-orgname">KENYA SCHOOL OF GOVERNMENT</div>

                      <div class="tag-name" id="pt-name">ROY MBECHE</div>

                      <div class="tag-position" id="pt-position"></div>

                      <div class="tag-pno" id="pt-pno" style="display: none;"></div>

                      <div class="tag-idno" id="pt-idno" style="display: none;"></div>

                      <div class="tag-dept" id="pt-dept">ICT</div>

                      <div class="tag-meta-strip">

                        <span class="tag-ref" id="pt-ref">KSG-REF-0000</span>

                        <span class="tag-date" id="pt-date"></span>

                      </div>

                    </div>

                  </div>

                </div>



              </div>

            </div>

          </div>

        </div>



        <!-- ── MANAGE TAGS ── -->

        <div class="page" id="page-manage">

          <div class="page-header">

            <h2>Manage Tags</h2>

            <p>View, search, edit, and manage all generated identification tags</p>

          </div>

          <div class="manage-header">

            <div class="search-box manage-search--wide">

              <span>🔍</span>

              <input type="text" placeholder="Search by name, ID, department…" oninput="filterTags(this.value)">

            </div>

            <select class="filter-select" id="filter-cat" onchange="filterTags()">

              <option value="">All Categories</option>

              <option>Staff</option><option>Attachee</option><option>Intern</option>

              <option>Visitor</option><option>Student</option><option>Trainer</option>

            </select>

            <select class="filter-select" id="filter-status" onchange="filterTags()">

              <option value="">All Status</option>

              <option>Active</option><option>Inactive</option><option>Expired</option>

            </select>

            <button class="btn btn-outline btn-sm" id="bulk-download-btn" onclick="downloadSelectedTags()" disabled>📄 Download Selected Tags (PDF)</button>

            <button class="btn btn-gold btn-sm" onclick="exportAll()">📥 Export CSV</button>

            <button class="btn btn-dark btn-sm" onclick="exportPDFReport()">📄 PDF Report</button>

          </div>

          <div class="table-card">

            <div class="table-header">

              <span class="table-title">All Tags</span>

              <span class="table-count" id="table-count">0 records</span>

            </div>

            <div class="table-wrap">

              <table class="data-table" id="manage-table">

                <thead>

                  <tr>

                    <th><input type="checkbox" id="select-all-visible" onchange="toggleSelectVisible(this.checked)"></th>

                    <th>#</th><th>Ref No.</th><th>Full Name</th><th>Department</th>

                    <th>Category</th><th>ID Number</th><th>Date</th><th>Status</th><th>Actions</th>

                  </tr>

                </thead>

                <tbody id="manage-tbody">

                  <tr><td colspan="10"><div class="empty-state"><div class="empty-icon">📋</div><p>No tags found. <a class="empty-link" onclick="gotoPage('generate',document.querySelectorAll('.nav-item')[1])">Generate your first tag →</a></p></div></td></tr>

                </tbody>

              </table>

            </div>

            <div class="pagination" id="pagination"></div>

          </div>

        </div>



        <!-- ── BULK GENERATION ── -->

        <div class="page" id="page-bulk">

          <div class="page-header">

            <h2>Bulk Tag Generation</h2>

            <p>Upload a CSV or Excel file to generate multiple tags at once</p>

          </div>

          <div class="bulk-layout">

            <div class="card">

              <div class="card-header"><span class="card-title">Upload File</span></div>

              <div class="card-body">

                <div class="drop-zone" id="drop-zone" onclick="document.getElementById('bulk-file').click()" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)">

                  <div class="drop-icon">📂</div>

                  <div class="drop-title">Drop your file here</div>

                  <div class="drop-hint">Supports CSV or Excel (.xlsx) · Click to browse</div>

                </div>

                <input type="file" id="bulk-file" accept=".csv,.xlsx,.xls,.xlsm" class="field-hidden" onchange="handleFileUpload(event)">

                <div class="divider"></div>

                <div class="card-title card-title--small">Required Columns:</div>

                <code class="bulk-code">full_name, department, category</code>

                <br><br>

                <button class="btn btn-outline btn-sm" onclick="downloadTemplate()">📥 Download Template</button>

                <div id="bulk-progress" class="hidden">

                  <div class="bulk-status" id="bulk-status">Processing…</div>

                  <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>

                </div>

                <div id="bulk-actions" class="bulk-inline hidden"></div>

              </div>

            </div>

            <div class="card">

              <div class="card-header">

                <span class="card-title">Preview & Validation</span>

                <span class="table-count" id="bulk-count">0 records</span>

              </div>

              <div class="bulk-preview-table">

                <table class="data-table" id="bulk-preview-table">

                  <thead><tr><th>Name</th><th>Dept</th><th>Category</th></tr></thead>

                  <tbody id="bulk-preview-body">

                    <tr><td colspan="5"><div class="empty-state"><div class="empty-icon">📤</div><p>Upload a file to preview data</p></div></td></tr>

                  </tbody>

                </table>

              </div>

              <div class="bulk-actions-row" id="bulk-gen-actions">

                <button class="btn btn-gold" id="btn-bulk-gen" onclick="generateBulk()" disabled>⚡ Generate All Tags in Bulk</button>

                <button class="btn btn-outline" onclick="clearBulk()">✕ Clear</button>

              </div>

            </div>

          </div>

        </div>



        <!-- ── REPORTS ── -->

        <div class="page" id="page-reports">

          <div class="page-header">

            <h2>Reports & Analytics</h2>

            <p>Insights into tag generation activity across departments and categories</p>

          </div>

          <div class="reports-grid">

            <div class="report-card">

              <h3>Tags by Category</h3>

              <div class="chart-bar-wrap" id="rpt-category"></div>

            </div>

            <div class="report-card">

              <h3>Tags by Department</h3>

              <div class="chart-bar-wrap" id="rpt-dept"></div>

            </div>

            <div class="report-card">

              <h3>Generation Trend</h3>

              <div class="chart-bar-wrap" id="rpt-trend"></div>

            </div>

          </div>

          <div class="card">

            <div class="card-header">

              <span class="card-title">Summary Statistics</span>

              <div class="page-header-actions">

                <button class="btn btn-gold btn-sm" onclick="exportAll()">📥 Export CSV</button>

                <button class="btn btn-dark btn-sm" onclick="exportPDFReport()">📄 PDF</button>

              </div>

            </div>

            <div class="card-body">

              <div class="stats-grid" id="report-stats"></div>

            </div>

          </div>

        </div>



        <!-- ── SETTINGS ── -->

        <div class="page" id="page-settings">

          <div class="page-header">

            <h2>System Settings</h2>

            <p>Configure the KSG Tag Generator to your needs</p>

          </div>

          <div class="settings-grid">

            <div class="settings-card card">

              <div class="card-header"><span class="card-title">Institution Details</span></div>

              <div class="settings-form">

                <div class="form-group">

                  <label>Institution Name</label>

                  <input type="text" id="set-org" value="Kenya School of Government">

                </div>

                <div class="form-group">

                  <label>System Name</label>

                  <input type="text" id="set-sys" value="KSG Tag Generator System">

                </div>

                <div class="form-group">

                  <label>Sub-title / Tagline</label>

                  <input type="text" id="set-tagline" value="Official Identification Tag">

                </div>

                <div class="form-group">

                  <label>Government Line</label>

                  <input type="text" id="set-gov" value="Republic of Kenya">

                </div>

                <button class="btn btn-gold btn-sm" onclick="saveSettings()">💾 Save Settings</button>

              </div>

            </div>

            <div class="settings-card card">

              <div class="card-header"><span class="card-title">Feature Toggles</span></div>

              <div class="settings-form">

                <div class="toggle"><span class="toggle-label">Dark Mode</span><div class="toggle-switch" id="tgl-dark" onclick="toggleSetting(this,'dark')"></div></div>

                <div class="toggle"><span class="toggle-label">QR Code on Tags</span><div class="toggle-switch on" id="tgl-qr" onclick="toggleSetting(this,'qr')"></div></div>

                <div class="toggle"><span class="toggle-label">Email Export</span><div class="toggle-switch" id="tgl-email" onclick="toggleSetting(this,'email')"></div></div>

                <div class="toggle"><span class="toggle-label">Duplicate ID Check</span><div class="toggle-switch on" id="tgl-dup" onclick="toggleSetting(this,'dup')"></div></div>

                <div class="toggle"><span class="toggle-label">Activity Logging</span><div class="toggle-switch on" id="tgl-log" onclick="toggleSetting(this,'log')"></div></div>

              </div>

            </div>

            <div class="settings-card card">

              <div class="card-header"><span class="card-title">Data Management</span></div>

              <div class="settings-form">

                <p class="settings-copy">Manage your locally stored tag data.</p>

                <button class="btn btn-outline btn-sm settings-action-btn" onclick="exportAll()">📥 Export All Tags (CSV)</button>

                <button class="btn btn-outline btn-sm settings-action-btn" onclick="exportPDFReport()">📄 Export PDF Report</button>

                <button class="btn btn-danger btn-sm settings-action-btn" onclick="clearAllData()">🗑️ Clear All Data</button>

              </div>

            </div>

            <div class="settings-card card">

              <div class="card-header"><span class="card-title">Developer Information</span></div>

              <div class="settings-form">

                <p class="settings-copy">Contact the developer for support or inquiries.</p>

                <div style="margin-top: 16px;">

                  <div style="margin-bottom: 12px;">

                    <strong style="font-size: 0.82rem; color: var(--ksg-dark);">Name:</strong>

                    <p style="margin: 4px 0 0 0; font-size: 0.87rem; color: var(--ksg-gray);">Roy Mbeche</p>

                  </div>

                  <div style="margin-bottom: 12px;">

                    <strong style="font-size: 0.82rem; color: var(--ksg-dark);">Contact:</strong>

                    <p style="margin: 4px 0 0 0; font-size: 0.87rem; color: var(--ksg-gray);">0799469163</p>

                  </div>

                  <div>

                    <strong style="font-size: 0.82rem; color: var(--ksg-dark);">Email:</strong>

                    <p style="margin: 4px 0 0 0; font-size: 0.87rem; color: var(--ksg-gray);">rollstechsolutions@gmail.com</p>

                  </div>

                </div>

              </div>

            </div>

            <div class="settings-card card" id="user-management-card" style="display:none;">

              <div class="card-header"><span class="card-title">User Management</span></div>

              <div class="settings-form">

                <p class="settings-copy">Approve or reject pending user registrations.</p>

                <button class="btn btn-outline btn-sm settings-action-btn" onclick="loadPendingUsers()">🔄 Refresh</button>

                <div id="pending-users-list" style="margin-top:12px;"></div>

                

                <hr style="margin:20px 0;border:0;border-top:1px solid #e5e7eb;">

                

                <h4 style="margin-bottom:12px;font-size:14px;">Create New User</h4>

                <div class="form-group">

                  <label>Full Name</label>

                  <input type="text" id="manual-reg-name" placeholder="John Doe">

                </div>

                <div class="form-group">

                  <label>Email Address</label>

                  <input type="email" id="manual-reg-email" placeholder="user@ksg.go.ke">

                </div>

                <div class="form-group">

                  <label>Password</label>

                  <input type="password" id="manual-reg-pass" placeholder="Min 8 characters">

                </div>

                <div class="form-group">

                  <label>Role</label>

                  <select id="manual-reg-role">

                    <option value="admin">Admin</option>

                    <option value="staff">Staff</option>

                    <option value="superadmin">Super Admin</option>

                  </select>

                </div>

                <button class="btn btn-primary btn-sm" onclick="createUserManual()">Create User</button>

              </div>

            </div>

          </div>

        </div>



        <!-- ── ACTIVITY LOGS ── -->

        <div class="page" id="page-logs">

          <div class="page-header">

            <h2>Activity Logs</h2>

            <p>Full audit trail of all system actions and events</p>

          </div>

          <div class="stats-grid stats-grid--compact">

            <div class="stat-card gold">

              <div class="stat-icon">📝</div>

              <div class="stat-value" id="log-total">0</div>

              <div class="stat-label">Total Events</div>

            </div>

            <div class="stat-card blue">

              <div class="stat-icon">👤</div>

              <div class="stat-value" id="log-users">1</div>

              <div class="stat-label">Active Users</div>

            </div>

            <div class="stat-card green">

              <div class="stat-icon">📅</div>

              <div class="stat-value" id="log-today">0</div>

              <div class="stat-label">Today's Events</div>

            </div>

            <div class="stat-card stat-card--danger">

              <div class="stat-icon">🔐</div>

              <div class="stat-value" id="log-role">—</div>

              <div class="stat-label">Your Role</div>

            </div>

          </div>

          <div class="card">

            <div class="card-header">

              <span class="card-title">System Activity</span>

              <div class="logs-toolbar">

                <input type="text" id="logs-search" class="logs-search" placeholder="Search logs...">

                <button class="btn btn-dark btn-sm" onclick="exportLogs()">📥 Export</button>

                <button class="btn btn-outline btn-sm hidden" id="clear-logs-btn" onclick="clearLogs()">🗑️ Clear Logs</button>

              </div>

            </div>

            <div class="card-body" id="logs-body">

              <div class="empty-state"><div class="empty-icon">📝</div><p>No activity logged yet</p></div>

            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

</div>



<!-- ── MODAL: VIEW TAG ── -->

<div class="modal-overlay" id="modal-view">

  <div class="modal modal--wide">

    <div class="modal-header">

      <span class="modal-title">Tag Preview</span>

      <button class="modal-close" onclick="closeModal('modal-view')">✕</button>

    </div>

    <div class="modal-body modal-body--split">

      <div class="modal-preview-shell">

        <div id="modal-tag-wrap"></div>

        <div class="modal-actions--centered">

          <button class="btn btn-gold btn-sm" onclick="downloadModalPDF()">📄 PDF</button>

          <button class="btn btn-dark btn-sm" onclick="downloadModalPNG()">🖼️ PNG</button>

          <button class="btn btn-outline btn-sm" onclick="printModal()">🖨️ Print</button>

        </div>

      </div>

      <div class="modal-form-stack">

      </div>

    </div>

  </div>

</div>



<!-- ── MODAL: EDIT TAG ── -->

<div class="modal-overlay" id="modal-edit">

  <div class="modal modal--dark">

    <div class="modal-header modal-header--dark">

      <span class="modal-title">Edit Tag</span>

      <button class="modal-close modal-close--dark" onclick="closeModal('modal-edit')">✕</button>

    </div>

    <div class="modal-body">

      <input type="hidden" id="edit-id">

      <div class="form-group modal-form-group">

        <label class="modal-form-label--dark">Full Name</label>

        <input type="text" id="edit-name" class="modal-form-input--dark">

      </div>

      <div class="form-group modal-form-group">

        <label class="modal-form-label--dark">Department</label>

        <input type="text" id="edit-dept" class="modal-form-input--dark">

      </div>

      <div class="form-group modal-form-group">

        <label class="modal-form-label--dark">Position</label>

        <input type="text" id="edit-pos" class="modal-form-input--dark">

      </div>

      <div class="form-group modal-form-group" id="edit-staff-fields" style="display: none;">

        <label class="modal-form-label--dark">P/No</label>

        <input type="text" id="edit-pno" class="modal-form-input--dark">

      </div>

      <div class="form-group modal-form-group" id="edit-staff-fields-2" style="display: none;">

        <label class="modal-form-label--dark">ID/No</label>

        <input type="text" id="edit-idno" class="modal-form-input--dark">

      </div>

      <div class="form-group modal-form-group">

        <label class="modal-form-label--dark">Status</label>

        <select id="edit-status" class="modal-form-input--dark">

          <option>Active</option><option>Inactive</option><option>Expired</option>

        </select>

      </div>

    </div>

    <div class="modal-footer modal-footer--dark">

      <button class="btn btn-outline" onclick="closeModal('modal-edit')">Cancel</button>

      <button class="btn btn-gold" onclick="downloadEditPDF()">📄 Download PDF</button>

      <button class="btn btn-gold" onclick="saveEdit()">💾 Save Changes</button>

    </div>

  </div>

</div>



<!-- ── MODAL: CONFIRM DELETE ── -->

<div class="modal-overlay" id="modal-delete">

  <div class="modal modal--compact">

    <div class="modal-header">

      <span class="modal-title">Confirm Delete</span>

      <button class="modal-close" onclick="closeModal('modal-delete')">✕</button>

    </div>

    <div class="modal-body">

      <p class="modal-copy">Are you sure you want to delete this tag? This action cannot be undone.</p>

    </div>

    <div class="modal-footer">

      <button class="btn btn-outline" onclick="closeModal('modal-delete')">Cancel</button>

      <button class="btn btn-danger" onclick="confirmDelete()">🗑️ Delete Tag</button>

    </div>

  </div>

</div>



<div id="toast-container"></div>

<script>

// ─── BOOT & INITIALIZATION ────────────────────────────────

load();

// Generate initial reference number

genRef();

// Init preview date

document.getElementById('pt-date').textContent=new Date().toLocaleDateString('en-GB');

// Ensure Supabase library is loaded before initializing

if(window.supabase && window.supabase.createClient){

  KSGSupabase.init();

  console.log('Supabase initialized successfully');

}else{

  console.error('Supabase library not loaded. Check CDN connection.');

}

// Boot auth

(async function bootAuth(){

  // Try to restore user from local storage first

  const storedUser = localStorage.getItem('ksg_user');

  if (storedUser) {

    try {

      STATE.user = JSON.parse(storedUser);

      // Load data from supabase if possible

      if (KSGDb.enabled()) {

        await loadFromSupabase();

      }

      // Show app

      document.getElementById('auth-screen').style.display='none';

      document.getElementById('app').style.display='block';

      applySettings();

      updateUserUI();

      refreshTagDataViews();

      return;

    } catch (e) {

      console.error('Failed to restore session:', e);

    }

  }

  

  // Show auth screen

  STATE.user = null;

  localStorage.removeItem('ksg_user');

  document.getElementById('auth-screen').style.display='flex';

  document.getElementById('app').style.display='none';

})();

// Init bulk gen actions visibility

document.getElementById('bulk-gen-actions').style.display='none';

// Restore dark mode

if(STATE.settings.darkMode) document.body.style.background='#0d1b2a';

</script>

<footer style="position: sticky; bottom: 0; margin-left: var(--sidebar-w); padding: 8px; text-align: center; font-size: 0.75rem; color: var(--ksg-gold); border-top: 1px solid var(--ksg-navy); background: var(--ksg-dark); z-index: 1000;">

  Copyright © 2026 Roy Mbeche. All Rights Reserved.

</footer>

</body>

</html>